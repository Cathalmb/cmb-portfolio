{
  "name": "cmb-portfolio",
  "version": "1.0.0",
  "description": "Cathal Mac an Bheatha — Product Designer & Creative Director",
  "scripts": {
    "build": "eleventy",
    "dev": "eleventy --serve --watch",
    "build:css": "tailwindcss -i ./src/css/input.css -o ./src/css/output.css --minify",
    "dev:css": "tailwindcss -i ./src/css/input.css -o ./src/css/output.css --watch",
    "start": "npm run dev:css & npm run dev"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "tailwindcss": "^3.4.0"
  }
}
