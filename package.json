{
  "name": "cmb-portfolio",
  "version": "1.0.0",
  "description": "Cathal Mac an Bheatha — Product Designer & Creative Director",
  "scripts": {
    "build:css": "tailwindcss -i ./src/css/main.css -o ./src/css/output.css --minify",
    "dev:css": "tailwindcss -i ./src/css/main.css -o ./src/css/output.css --watch",
    "build:11ty": "eleventy",
    "build": "npm run build:css && npm run build:11ty",
    "dev": "npm run dev:css & eleventy --serve --watch"
  },
  "devDependencies": {
    "@11ty/eleventy": "^2.0.1",
    "tailwindcss": "^3.4.0"
  }
}
