<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Case Study · Cathal Mac an Bheatha</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/output.css">
  <link rel="stylesheet" href="/css/case-study.css">
</head>
<body>

  {% include "nav.njk" %}

  <!-- CASE STUDY CARD -->
  <div class="card" style="margin-top:120px;">
    <div class="container" style="padding-top:80px;padding-bottom:80px;">

      <!-- HERO -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:40px;align-items:end;margin-bottom:48px;">
        <div>
          <h1 class="h1" style="margin-bottom:48px;">{{ title }}</h1>
          <div style="display:flex;gap:40px;flex-wrap:wrap;">
            <div style="display:flex;gap:12px;align-items:baseline;">
              <span style="font-family:'Inter',sans-serif;font-size:16px;font-weight:500;color:#5a6857;">Scope</span>
              <span style="font-family:'Inter',sans-serif;font-size:16px;font-weight:500;color:#121212;">{{ scope }}</span>
            </div>
            <span style="font-family:'Inter',sans-serif;font-size:16px;color:#5a6857;">/</span>
            <div style="display:flex;gap:12px;align-items:baseline;">
              <span style="font-family:'Inter',sans-serif;font-size:16px;font-weight:500;color:#5a6857;">Client</span>
              <span style="font-family:'Inter',sans-serif;font-size:16px;font-weight:500;color:#121212;">{{ client }}</span>
            </div>
          </div>
        </div>
        <div>
          <p class="body-lg">{{ intro }}</p>
        </div>
      </div>

      <!-- Hero image -->
      <div class="cs-img-placeholder" style="height:620px;border-radius:24px;margin-bottom:80px;">
        {% if heroImage %}
          <img src="{{ heroImage }}" alt="{{ title }} hero image" style="width:100%;height:100%;object-fit:cover;border-radius:24px;">
        {% else %}
          <span class="cs-img-label">Hero image</span>
        {% endif %}
      </div>

      <!-- Page content injected here -->
      {{ content | safe }}

    </div>
  </div>

  <!-- NEXT PROJECT -->
  {% if nextProject %}
  <div style="background:#fff;margin:16px 16px 0;border-radius:32px;overflow:hidden;">
    <div style="max-width:1440px;margin:0 auto;padding:64px 40px;">
      <div style="display:grid;grid-template-columns:auto 1fr;gap:0;align-items:start;">
        <div style="padding-right:40px;border-right:1px solid rgba(18,18,18,0.08);">
          <p style="font-family:'Bricolage Grotesque',sans-serif;font-size:25px;font-weight:700;color:#121212;letter-spacing:-1px;margin-bottom:24px;">/ Next Project</p>
          <a href="{{ nextProject.url }}" style="text-decoration:none;">
            <h2 style="font-family:'Bricolage Grotesque',sans-serif;font-size:95px;font-weight:700;color:#121212;letter-spacing:-2.5px;line-height:0.9;transition:color 0.2s;"
              onmouseover="this.style.color='#5a6857'"
              onmouseout="this.style.color='#121212'">{{ nextProject.title }}</h2>
          </a>
        </div>
        <div style="padding-left:40px;padding-top:64px;">
          <p style="font-family:'Inter',sans-serif;font-size:25px;font-weight:500;color:#121212;letter-spacing:-1px;line-height:1.3;max-width:540px;">{{ nextProject.description }}</p>
        </div>
      </div>
    </div>
    {% if nextProject.previewImage %}
    <div style="height:340px;background:rgba(90,104,87,0.1);overflow:hidden;">
      <img src="{{ nextProject.previewImage }}" alt="{{ nextProject.title }}" style="width:100%;height:100%;object-fit:cover;">
    </div>
    {% else %}
    <div style="height:340px;background:rgba(90,104,87,0.1);"></div>
    {% endif %}
  </div>
  {% endif %}

  {% include "footer.njk" %}
  {% include "scripts.njk" %}

</body>
</html>
