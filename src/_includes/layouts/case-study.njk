<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — Case Study · Cathal Mac an Bheatha</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700;12..96,800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/output.css">
  <link rel="stylesheet" href="/css/case-study.css">
</head>
<body>

  {% include "nav.njk" %}

  <!-- CASE STUDY CARD -->
  <div class="card" style="margin-top:120px;overflow:hidden;">
    <div style="max-width:1440px;margin:0 auto;padding:80px 40px 0;">

      <!-- HERO — title + meta left, intro text right starting at ~1/3 down -->
      <div class="cs-hero-grid" style="display:grid;grid-template-columns:1fr 1fr;gap:40px;margin-bottom:48px;">
        <div>
          <h1 class="h1" style="margin-bottom:40px;">{{ title }}</h1>
          <div class="cs-meta-row" style="display:flex;gap:0;align-items:baseline;flex-wrap:wrap;column-gap:24px;row-gap:8px;">
            <span class="cs-meta-item" style="display:contents;"><span style="font-family:'Inter',sans-serif;font-size:16px;font-weight:500;color:#5a6857;">Scope</span>
            <span style="font-family:'Inter',sans-serif;font-size:16px;font-weight:500;color:#121212;margin-right:16px;">{{ scope }}</span></span>
            <span class="cs-meta-slash" style="font-family:'Inter',sans-serif;font-size:16px;color:#5a6857;margin-right:16px;">/</span>
            <span class="cs-meta-item" style="display:contents;"><span style="font-family:'Inter',sans-serif;font-size:16px;font-weight:500;color:#5a6857;">Client</span>
            <span style="font-family:'Inter',sans-serif;font-size:16px;font-weight:500;color:#121212;">{{ client }}</span></span>
          </div>
        </div>
        <!-- Intro text — sits at roughly 1/3 down the left column height, matching Figma top:365px -->
        <div style="padding-top:149px;">
          <p class="body-lg cs-hero-intro">{{ intro }}</p>
        </div>
      </div>

      <!-- Hero image -->
      <div class="cs-full-img-tall" style="height:765px;border-radius:24px;overflow:hidden;margin-bottom:96px;">
        {% if heroImage %}
          <img src="{{ heroImage }}" alt="{{ title }}" style="width:100%;height:100%;object-fit:cover;display:block;">
        {% else %}
          <div style="width:100%;height:100%;background:rgba(90,104,87,0.15);display:flex;align-items:center;justify-content:center;">
            <span style="font-family:'Inter',sans-serif;font-size:11px;color:rgba(90,104,87,0.45);letter-spacing:0.1em;text-transform:uppercase;">Hero image</span>
          </div>
        {% endif %}
      </div>

      <!-- Page content -->
      {{ content | safe }}

    </div>
    <div style="padding-bottom:96px;"></div>
  </div>

  <!-- NEXT PROJECT -->
  {% if nextProject %}
  <div style="background:#fff;margin:16px 16px 0;border-radius:32px;overflow:hidden;">
    <div style="max-width:1440px;margin:0 auto;padding:64px 40px 0;">
      <p style="font-family:'Bricolage Grotesque',sans-serif;font-size:25px;font-weight:700;color:#121212;letter-spacing:-1px;margin-bottom:40px;">/ Next Project</p>
      <div class="cs-next-grid" style="display:grid;grid-template-columns:7fr 5fr;gap:40px;align-items:end;padding-bottom:64px;">
        <a href="{{ nextProject.url }}" style="text-decoration:none;display:block;">
          <h2 class="cs-next-title" style="font-family:'Bricolage Grotesque',sans-serif;font-size:95px;font-weight:700;color:#121212;letter-spacing:-2.5px;line-height:0.95;transition:color 0.2s;"
            onmouseover="this.style.color='#5a6857'"
            onmouseout="this.style.color='#121212'">{{ nextProject.title }}</h2>
        </a>
        <p style="font-family:'Inter',sans-serif;font-size:25px;font-weight:500;color:#121212;letter-spacing:-1px;line-height:1.3;">{{ nextProject.description }}</p>
      </div>
    </div>
    <!-- Preview image — inside container, top radius only -->
    <div style="max-width:1440px;margin:0 auto;padding:0 40px;">
      <div style="height:434px;border-radius:24px 24px 0 0;overflow:hidden;">
        {% if nextProject.previewImage %}
          <img src="{{ nextProject.previewImage }}" alt="{{ nextProject.title }}" style="width:100%;height:100%;object-fit:cover;display:block;">
        {% else %}
          <div style="width:100%;height:100%;background:rgba(90,104,87,0.1);"></div>
        {% endif %}
      </div>
    </div>
  </div>
  {% endif %}

  {% include "footer.njk" %}
  {% include "scripts.njk" %}

</body>
</html>